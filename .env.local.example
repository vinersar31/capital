# ──────────────────────────────────────────────────────────────
# Firebase Web App config
# ──────────────────────────────────────────────────────────────
# 1. Go to https://console.firebase.google.com/ and create a project.
# 2. Add a Web App (</>) and copy the config values below.
# 3. In Build > Authentication, enable the "Google" sign-in provider.
# 4. In Build > Firestore Database, create a database (production mode).
# 5. Copy this file to ".env.local" and paste your values.
#
# NOTE: Until these are filled in, the app runs in LOCAL MODE using
# your browser's localStorage (with seeded sample data) — no login needed.
# ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──────────────────────────────────────────────────────────────
# Email export (SERVER-SIDE secrets — never exposed to the browser)
# ──────────────────────────────────────────────────────────────
# The "Email Excel" button posts your portfolio to /api/export, which
# generates an .xlsx report and emails it to EXPORT_EMAIL_TO over SMTP.
# The recipient is read ONLY from this env var, so the endpoint can't be
# used to mail arbitrary addresses.
#
# Gmail: enable 2-Step Verification, then create an App Password
# (Google Account → Security → App passwords) and use it as SMTP_PASS.

# Who receives the report (keep this out of source control).
EXPORT_EMAIL_TO=

# SMTP server (Gmail example shown).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
